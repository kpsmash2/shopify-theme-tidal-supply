{% doc %}
  @prompt
    Create vertical divider lines on either side of the page that run the full length of the page, bordering the main content containers. The lines should be fixed/sticky on the left and right edges of the main content area, spanning the full page height, and styled to complement the existing theme design.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vertical-dividers-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: {{ block.settings.content_width }}px;
    height: 100vh;
    pointer-events: none;
    z-index: {{ block.settings.z_index }};
    display: block;
  }

  .ai-vertical-dividers-{{ ai_gen_id }}::before,
  .ai-vertical-dividers-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 0;
    width: {{ block.settings.line_thickness }}px;
    height: 100%;
    background-color: {{ block.settings.line_color }};
    opacity: {{ block.settings.line_opacity | divided_by: 100.0 }};
  }

  .ai-vertical-dividers-{{ ai_gen_id }}::before {
    left: 0;
  }

  .ai-vertical-dividers-{{ ai_gen_id }}::after {
    right: 0;
  }

  @media screen and (max-width: {{ block.settings.content_width }}px) {
    .ai-vertical-dividers-{{ ai_gen_id }} {
      display: none;
    }
  }

  {% if block.settings.hide_on_mobile %}
    @media screen and (max-width: 749px) {
      .ai-vertical-dividers-{{ ai_gen_id }} {
        display: none;
      }
    }
  {% endif %}
{% endstyle %}

<div class="ai-vertical-dividers-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Vertical dividers",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200,
      "info": "Should match your theme's page width setting"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Line style"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line color",
      "default": "#3d081b"
    },
    {
      "type": "range",
      "id": "line_opacity",
      "label": "Line opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "range",
      "id": "z_index",
      "label": "Layer position",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10,
      "info": "Higher values appear above other content"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Vertical dividers"
    }
  ]
}
{% endschema %}
