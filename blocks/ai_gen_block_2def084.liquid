{% doc %}
  @prompt
    add a horiztonal divder to every section that spans the full width of the page and resizes on mobile, add opacity adjustment
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .ai-divider-container-{{ ai_gen_id }} {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding-top: {{ block.settings.spacing_top }}px;
    padding-bottom: {{ block.settings.spacing_bottom }}px;
  }

  .ai-divider-line-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    border: none;
    margin: 0;
    {% if block.settings.divider_style == 'dashed' %}
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.divider_color }} 0px,
        {{ block.settings.divider_color }} 10px,
        transparent 10px,
        transparent 20px
      );
    {% elsif block.settings.divider_style == 'dotted' %}
      background: repeating-linear-gradient(
        to right,
        {{ block.settings.divider_color }} 0px,
        {{ block.settings.divider_color }} 5px,
        transparent 5px,
        transparent 15px
      );
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-divider-container-{{ ai_gen_id }} {
      padding-top: {{ block.settings.spacing_top_mobile }}px;
      padding-bottom: {{ block.settings.spacing_bottom_mobile }}px;
    }

    .ai-divider-line-{{ ai_gen_id }} {
      height: {{ block.settings.divider_thickness_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-divider-container-{{ ai_gen_id }}">
    <hr class="ai-divider-line-{{ ai_gen_id }}" aria-hidden="true">
  </div>
</div>

{% schema %}
{
  "name": "Horizontal divider",
  "settings": [
    {
      "type": "header",
      "content": "Divider style"
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color",
      "default": "#3d081b"
    },
    {
      "type": "range",
      "id": "divider_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "Thickness (desktop)",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "divider_thickness_mobile",
      "label": "Thickness (mobile)",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing (desktop)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "spacing_top_mobile",
      "label": "Top spacing (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom_mobile",
      "label": "Bottom spacing (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Horizontal divider"
    }
  ]
}
{% endschema %}
